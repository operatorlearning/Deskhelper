# 本地模型路径配置（可选，留空则自动从HuggingFace下载）
VISION_MODEL_PATH=

# 是否使用4bit量化节省显存（true/false）
USE_4BIT=false

# 推理设备（cuda / cpu）
VISION_DEVICE=cuda
WHISPER_DEVICE=cuda

# Whisper模型规格 (tiny/base/small/medium/large)
WHISPER_MODEL=medium

# TTS引擎 (pyttsx3 / edge-tts)
TTS_ENGINE=pyttsx3

# BGE嵌入模型路径（留空自动下载）
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5

# 记忆保留天数（-1永久）
MEMORY_RETENTION_DAYS=-1

# Web UI端口
UI_PORT=7860

# 日志级别 (DEBUG/INFO/WARNING/ERROR)
LOG_LEVEL=INFO

# HuggingFace镜像（国内加速，可选，去掉#号启用）
# HF_ENDPOINT=https://hf-mirror.com

